# Copy to ~/.config/molt/profile.env or $MOLT_ROOT/.molt/profile.env
# All variables are optional; unset keys use built-in defaults.

# GITHUB_ORG=molt-digiflux
# MOLT_DEFAULT_BRANCH=env/staging
# MOLT_DEFAULT_PREFIX=be
# MERGE_STYLE=merge

# Override promote chain (bash array — only in profile file, not exportable):
# MOLT_ENV_CHAIN=(
#   "env/staging:env/uat"
#   "env/uat:env/preprod"
#   "env/preprod:env/prod"
# )

# GIT_PROMOTE_EMAIL=you@example.com
# GIT_PROMOTE_NAME=Your Name

# Commits in ~/Workspace/molt/scripts (local repo only; overrides promote identity)
# MOLT_SCRIPTS_GIT_NAME=Your Name
# MOLT_SCRIPTS_GIT_EMAIL=you@example.com
