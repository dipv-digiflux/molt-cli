#!/usr/bin/env bash
# Molt workspace CLI — run from anywhere (add scripts/ to PATH or symlink this file).
#
# Usage:
#   molt check [--prefix be|web|mobile] [--repo NAME]
#   molt clone [clone-all flags]
#   molt pull  [pull-all flags]
#   molt promote list | merge-all | promote ...
#
set -euo pipefail

MOLT_CLI="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export MOLT_ROOT="${MOLT_ROOT:-$(cd "$MOLT_CLI/.." && pwd)}"

# shellcheck source=lib/repos-common.sh
source "$MOLT_CLI/lib/repos-common.sh"
# shellcheck source=lib/check.sh
source "$MOLT_CLI/lib/check.sh"
# shellcheck source=lib/git-local.sh
source "$MOLT_CLI/lib/git-local.sh"

usage() {
  cat <<EOF
molt — workspace scripts for ${GITHUB_ORG:-molt}

Commands:
  check              Verify tools, gh auth, and local repos
  setup-git          Init local git for this scripts repo (version history)
  git                status | log | diff | tag in the scripts repo
  clone              Clone org repos into molt/{be,web,mobile}/
  pull               Checkout branch and pull all local repos
  promote            Env branch promotion (GitHub PRs or git push)

Config (first file found):
  \$MOLT_PROFILE
  ~/.config/molt/profile.env
  \$MOLT_ROOT/.molt/profile.env

Env overrides: MOLT_ROOT, GITHUB_ORG, MOLT_DEFAULT_BRANCH, MOLT_DEFAULT_PREFIX,
  WORKSPACE_ROOT, MERGE_STYLE

Examples:
  molt setup-git --commit
  molt git log --oneline -5
  molt check
  molt check --prefix web --branch env/staging
  molt clone --prefix be --dry-run
  molt pull --rebase
  molt promote list
  molt promote merge-all --dry-run

Run 'molt <command> --help' on clone/pull/promote for more flags.
EOF
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    check)     cmd_check "$@" ;;
    setup-git) cmd_setup_git "$@" ;;
    git)       cmd_git "$@" ;;
    clone)     exec "$MOLT_CLI/clone-all.sh" "$@" ;;
    pull)   exec "$MOLT_CLI/pull-all.sh" "$@" ;;
    promote) exec "$MOLT_CLI/gh-org-env-promote.sh" "$@" ;;
    ""|-h|--help) usage; exit 0 ;;
    *)
      die "unknown command: $cmd (try: molt --help)"
      ;;
  esac
}

main "$@"
